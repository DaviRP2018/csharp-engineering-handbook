<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- left side -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="WPF Async Demonstration" FontSize="20" Margin="0,0,0,20"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Indeterminate Progress Bar (Visual Work):" Margin="0,10,0,5" />
            <ProgressBar x:Name="MainProgressBar" IsIndeterminate="True" Height="20" Width="300"
                         Foreground="Green" />

            <Button x:Name="HeavyWorkButton"
                    Content="Start Heavy Work"
                    Margin="0,30,0,0"
                    Padding="10"
                    Click="HeavyWorkButton_OnClick" />

            <Button x:Name="CancelTask"
                    Content="Cancel Task"
                    Margin="0,10,0,0"
                    Padding="10"
                    Click="CancelTask_OnClick" />

            <Button x:Name="CycleColorButton"
                    Content="Cycle Color"
                    Margin="0,10,0,0"
                    Padding="10"
                    Click="CycleColorButton_OnClick" />

            <Button x:Name="ShowLastTaskStatus"
                    Content="Show Last Task Status"
                    Margin="0, 10, 0, 0"
                    Padding="10"
                    Click="ShowLastTaskStatus_OnClick" />

            <Button x:Name="ClearMessageLog"
                    Content="Clear Message Log"
                    Margin="0, 10, 0, 0"
                    Padding="10"
                    Click="ClearMessageLog_OnClick" />

            <TextBlock x:Name="StatusTextBlock"
                       Text="Status: Ready"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"
                       Foreground="DarkGreen" />
        </StackPanel>

        <!-- right side -->
        <Grid Grid.Column="1" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Message Log"
                       FontWeight="Bold"
                       Margin="0,0,0,5"
                       Grid.Row="0" />

            <ListBox x:Name="JobsListBox"
                     Grid.Row="1"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Window>