<Window x:Class="Collections.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="800">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Performance">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Collections Performance Comparison" FontSize="18"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center" />

                    <GroupBox Header="Memory (ArrayList vs List&lt;int&gt;)" Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <Button x:Name="btnOld"
                                    Content="Generate 10M Items (ArrayList - Boxed)"
                                    Width="280"
                                    Height="40" Margin="5" Click="btnOld_Click" />
                            <Button x:Name="btnNew"
                                    Content="Generate 10M Items (List&lt;int&gt; - Generic)"
                                    Width="280" Height="40" Margin="5" Click="btnNew_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Lookup Performance (HashSet vs List)" Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <Button x:Name="btnListLookup" Content="Run List Lookup (O(n))"
                                    Width="280"
                                    Height="40" Margin="5" Click="btnListLookup_Click" />
                            <Button x:Name="btnHashLookup" Content="Run HashSet Lookup (O(1))"
                                    Width="280"
                                    Height="40" Margin="5" Click="btnHashLookup_Click" />
                        </StackPanel>
                    </GroupBox>

                    <Button x:Name="btnClear" Content="Clear Memory" Width="280" Height="40"
                            Margin="5"
                            Click="btnClear_Click" />
                    <TextBlock x:Name="statusText" Text="Status: Idle" Margin="0,20,0,0"
                               HorizontalAlignment="Center" />

                    <ProgressBar x:Name="MainProgressBar" IsIndeterminate="True" Height="20"
                                 Width="280"
                                 Margin="0,20,0,0" Foreground="Green" />
                </StackPanel>
            </TabItem>

            <TabItem Header="FIFO &amp; LIFO">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- FIFO (Queue) -->
                    <GroupBox Header="FIFO (Queue&lt;string&gt;)" Grid.Column="0" Margin="10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Button x:Name="btnEnqueue" Content="Enqueue (Add)" Height="30"
                                        Margin="5" Click="btnEnqueue_Click" />
                                <Button x:Name="btnDequeue" Content="Dequeue (Remove)" Height="30"
                                        Margin="5" Click="btnDequeue_Click" />
                            </StackPanel>
                            <ListBox x:Name="listQueue" />
                        </DockPanel>
                    </GroupBox>

                    <!-- LIFO (Stack) -->
                    <GroupBox Header="LIFO (Stack&lt;string&gt;)" Grid.Column="1" Margin="10">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Button x:Name="btnPush" Content="Push (Add)" Height="30"
                                        Margin="5" Click="btnPush_Click" />
                                <Button x:Name="btnPop" Content="Pop (Remove)" Height="30"
                                        Margin="5" Click="btnPop_Click" />
                            </StackPanel>
                            <ListBox x:Name="listStack" />
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="ImmutableList">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Structural Sharing Demonstration"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                               Margin="0,0,0,10" />

                    <GroupBox Header="Common List&lt;int&gt;" Grid.Row="1" Grid.Column="0"
                              Margin="5">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <Button x:Name="btnAddToList" Content="Add Item" Height="30"
                                        Margin="5"
                                        Click="btnAddToList_Click" />
                                <Button x:Name="btnCopyList" Content="Full Copy (new List(old))"
                                        Height="30"
                                        Margin="5" Click="btnCopyList_Click" />
                                <TextBlock x:Name="listAddressLabel" Text="List Address: -"
                                           Margin="5"
                                           HorizontalAlignment="Center" FontWeight="Bold" />
                            </StackPanel>
                            <ListBox x:Name="listCommon">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Value: " />
                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" />
                                            <TextBlock Text=" | Address: " Margin="10,0,0,0" />
                                            <TextBlock Text="{Binding Address}"
                                                       FontFamily="Consolas" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="ImmutableList&lt;int&gt;" Grid.Row="1" Grid.Column="1"
                              Margin="5">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <Button x:Name="btnAddImmutable"
                                        Content="Add Item (new instance created)"
                                        Height="30" Margin="5" Click="btnAddImmutable_Click" />
                                <Button x:Name="btnCopyImmutable" Content="Copy Reference"
                                        Height="30"
                                        Margin="5" Click="btnCopyImmutable_Click" />
                                <TextBlock x:Name="immutableAddressLabel" Text="List Address: -"
                                           Margin="5"
                                           HorizontalAlignment="Center" FontWeight="Bold" />
                            </StackPanel>
                            <ListBox x:Name="listImmutable">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Value: " />
                                            <TextBlock Text="{Binding Value}" FontWeight="Bold" />
                                            <TextBlock Text=" | Address: " Margin="10,0,0,0" />
                                            <TextBlock Text="{Binding Address}"
                                                       FontFamily="Consolas" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>