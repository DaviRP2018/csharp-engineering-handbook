<Window x:Class="Collections.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Collections Performance Comparison" FontSize="18" Margin="0,0,0,20"
                       HorizontalAlignment="Center" />
            <Button x:Name="btnOld" Content="Generate 10M Items (ArrayList - Boxed)" Width="250"
                    Height="40" Margin="5" Click="btnOld_Click" />
            <Button x:Name="btnNew" Content="Generate 10M Items (List&lt;int&gt; - Generic)"
                    Width="250" Height="40" Margin="5" Click="btnNew_Click" />
            <Button x:Name="btnClear" Content="Clear Memory" Width="250" Height="40" Margin="5"
                    Click="btnClear_Click" />
            <TextBlock x:Name="statusText" Text="Status: Idle" Margin="0,20,0,0"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>