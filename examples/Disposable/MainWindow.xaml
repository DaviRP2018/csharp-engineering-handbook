<Window x:Class="Disposable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="800">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Unmanaged Memory">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Memory Demonstration" FontSize="18"
                               Margin="0, 0, 0, 10"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Check your IDE's memory monitor"
                               Margin="0, 0, 0, 20"
                               HorizontalAlignment="Center" />

                    <GroupBox Header="Memory Allocation" Margin="0, 0, 0, 20">
                        <StackPanel Margin="10">
                            <Button
                                Content="Allocate 5MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateUnmanagedMemory_OnClick" Tag="5" />
                            <Button
                                Content="Allocate 25MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateUnmanagedMemory_OnClick" Tag="25" />
                            <Button
                                Content="Allocate 50MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateUnmanagedMemory_OnClick" Tag="50" />
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Clear Memory" Width="280" Height="40"
                            Margin="5"
                            Click="ClearUnmanagedMemory_OnClick"
                            Background="DarkGreen"
                            Foreground="White" />
                    <TextBlock x:Name="UnmanagedStatusText" Text="Status: Idle"
                               Margin="0, 20, 0, 0"
                               HorizontalAlignment="Center" Foreground="Green" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Managed Memory">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Memory Demonstration" FontSize="18"
                               Margin="0, 0, 0, 10"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Check your IDE's memory monitor"
                               Margin="0, 0, 0, 20"
                               HorizontalAlignment="Center" />

                    <GroupBox Header="Managed Allocation" Margin="0, 0, 0, 20">
                        <StackPanel Margin="10">
                            <Button
                                Content="Allocate 25MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateManagedMemory_OnClick" Tag="25" />
                            <Button
                                Content="Allocate 50MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateManagedMemory_OnClick" Tag="50" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Allocation With Reference" Margin="0, 0, 0, 20">
                        <StackPanel Margin="10">
                            <Button
                                Content="Allocate 25MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateReferencedMemory_OnClick" Tag="25" />
                            <Button
                                Content="Allocate 50MB"
                                Width="280"
                                Height="40" Margin="5"
                                Click="AllocateReferencedMemory_OnClick" Tag="50" />
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Clear Memory" Width="280" Height="40"
                            Margin="5"
                            Click="ClearManagedMemory_OnClick"
                            Background="DarkGreen"
                            Foreground="White" />
                    <Button Content="Remove References" Width="280" Height="40"
                            Margin="5"
                            Click="RemoveReferences_OnClick" />
                    <TextBlock x:Name="ManagedStatusText" Text="Status: Idle" Margin="0, 20, 0, 0"
                               HorizontalAlignment="Center" Foreground="Green" />
                </StackPanel>
            </TabItem>

            <TabItem Header="IDisposable">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Controls -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Self-Disposing Memory" FontSize="18" Margin="0,0,0,10"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Allocates memory that disposes after 5s"
                                   Margin="0,0,0,20" HorizontalAlignment="Center" />

                        <GroupBox Header="Allocate and Auto-Dispose" Margin="0,0,0,20">
                            <StackPanel Margin="10">
                                <Button Content="Allocate 50MB" Width="200" Height="40" Margin="5"
                                        Click="AllocateDisposable_OnClick" Tag="50" />
                                <Button Content="Allocate 100MB" Width="200" Height="40"
                                        Margin="5"
                                        Click="AllocateDisposable_OnClick" Tag="100" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Right Column: List of pointers -->
                    <GroupBox Grid.Column="1" Header="Active Pointers (Auto-removing)" Margin="10">
                        <ListBox ItemsSource="{Binding DisposableItems}"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Text="{Binding Pointer, StringFormat='Ptr: {0}'}"
                                            VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock
                                                Text="{Binding SizeMB, StringFormat='({0}MB)'}"
                                                Margin="5,0" VerticalAlignment="Center"
                                                Foreground="Gray" />
                                            <TextBlock
                                                Text="{Binding SecondsRemaining, StringFormat='Expires in {0}s'}"
                                                FontWeight="Bold" VerticalAlignment="Center"
                                                Foreground="DarkRed" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>